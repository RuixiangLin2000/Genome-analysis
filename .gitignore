# =========================
# 1. Hidden and temporary files
# =========================
.*
!.gitignore
~*
*.swp
*.tmp

# =========================
# 2. Raw sequencing data
# =========================
*.fastq
*.fastq.gz
*.fasta
*.fa

# =========================

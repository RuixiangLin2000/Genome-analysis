# =========================
results/
output/
intermediate/
scratch/

# =========================
# 5. Log files
# =========================
*.log

# =========================
# 6. Annotation files
# =========================
*.gtf
*.gff
*.bed

# =========================
# 7. R data and tabular files
# =========================
*.Rdata
*.tsv
*.csv

# =========================
# 8. Symlinks (if present)
# =========================
*.lnk

# =========================
# 9. System-specific files
# =========================
.DS_Store
